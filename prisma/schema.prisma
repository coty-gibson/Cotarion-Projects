generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts        Account[]
  sessions        Session[]
  applicationUser ApplicationUser?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationUsers ApplicationUser[]
  clients          Client[]
  clientSequence   ClientSequence?
}

model ApplicationUser {
  id        String                @id @default(cuid())
  authUserId String               @unique
  companyId String
  email     String                @unique
  name      String?
  status    ApplicationUserStatus @default(ACTIVE)
  role      ApplicationUserRole   @default(MEMBER)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  authUser User    @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  company  Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  ownedClients Client[]
}

enum ApplicationUserStatus {
  ACTIVE
  INACTIVE
}

enum ApplicationUserRole {
  MEMBER
}

model ClientSequence {
  companyId String @id
  lastValue Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Client {
  id             String       @id @default(cuid())
  clientNumber   String       @unique
  companyId      String
  ownerId        String
  name           String
  normalizedName String
  businessType   ClientBusinessType?
  imageUrl       String?
  website        String?
  street         String?
  city           String?
  state          String?
  postalCode     String?
  notes          String?      @db.Text
  status         ClientStatus @default(PROSPECT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Restrict)
  owner    ApplicationUser @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  contacts ClientContact[]

  @@index([companyId, status])
  @@index([companyId, normalizedName])
  @@index([companyId, updatedAt])
  @@index([ownerId])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  firstName String
  lastName  String
  jobTitle  String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
  @@index([phone])
}

enum ClientStatus {
  PROSPECT
  ACTIVE_CLIENT
  INACTIVE
}

enum ClientBusinessType {
  ACCOUNTING
  ARCHITECTURE
  AUTOMOTIVE
  CONSTRUCTION
  CONSULTING
  EDUCATION
  FINANCIAL_SERVICES
  GOVERNMENT
  HEALTHCARE
  HOSPITALITY
  LEGAL
  MANUFACTURING
  NONPROFIT
  REAL_ESTATE
  RESTAURANT_FOOD_SERVICE
  RETAIL
  TECHNOLOGY
  TRANSPORTATION_LOGISTICS
  OTHER
}
