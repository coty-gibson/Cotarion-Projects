generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts        Account[]
  sessions        Session[]
  applicationUser ApplicationUser?
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationUsers             ApplicationUser[]
  clients                      Client[]
  clientSequence               ClientSequence?
  pricingProjects              PricingProject[]
  serviceCatalogItems          ServiceCatalogItem[]
  pricingConfiguration         PricingConfiguration?
  pricingConfigurationVersions PricingConfigurationVersion[]
  operatingGroups              OperatingGroup[]
  engagementTypePolicies       EngagementTypePolicyVersion[]
  proposals                    Proposal[]
}

model ApplicationUser {
  id         String                @id @default(cuid())
  authUserId String                @unique
  companyId  String
  email      String                @unique
  name       String?
  status     ApplicationUserStatus @default(ACTIVE)
  role       ApplicationUserRole   @default(MEMBER)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  authUser             User             @relation(fields: [authUserId], references: [id], onDelete: Cascade)
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  ownedClients         Client[]
  ownedPricingProjects PricingProject[]
  ownedProposals       Proposal[]

  @@unique([id, companyId])
}

enum ApplicationUserStatus {
  ACTIVE
  INACTIVE
}

enum ApplicationUserRole {
  MEMBER
}

model ClientSequence {
  companyId String @id
  lastValue Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Client {
  id             String              @id @default(cuid())
  clientNumber   String              @unique
  companyId      String
  ownerId        String
  name           String
  normalizedName String
  businessType   ClientBusinessType?
  imageUrl       String?
  website        String?
  street         String?
  city           String?
  state          String?
  postalCode     String?
  notes          String?             @db.Text
  status         ClientStatus        @default(PROSPECT)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  owner           ApplicationUser  @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  contacts        ClientContact[]
  pricingProjects PricingProject[]
  proposals       Proposal[]

  @@unique([id, companyId])
  @@index([companyId, status])
  @@index([companyId, normalizedName])
  @@index([companyId, updatedAt])
  @@index([ownerId])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  firstName String
  lastName  String
  jobTitle  String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([email])
  @@index([phone])
}

enum ClientStatus {
  PROSPECT
  ACTIVE_CLIENT
  INACTIVE
}

enum ClientBusinessType {
  ACCOUNTING
  ARCHITECTURE
  AUTOMOTIVE
  CONSTRUCTION
  CONSULTING
  EDUCATION
  FINANCIAL_SERVICES
  GOVERNMENT
  HEALTHCARE
  HOSPITALITY
  LEGAL
  MANUFACTURING
  NONPROFIT
  REAL_ESTATE
  RESTAURANT_FOOD_SERVICE
  RETAIL
  TECHNOLOGY
  TRANSPORTATION_LOGISTICS
  OTHER
}

enum PricingProjectStatus {
  DRAFT
  IN_REVIEW
  QUOTED
  ARCHIVED
}

enum PricingModelType {
  PROJECT
  FIXED_RETAINER
  PROFIT_SHARE_RETAINER
  HYBRID_RETAINER
  ADVISORY_HOURLY
}

enum PricingCurrency {
  USD
}

enum ServiceCatalogItemStatus {
  ACTIVE
  INACTIVE
}

enum PricingConfigurationVersionStatus {
  ACTIVE
  RETIRED
}

model PricingProjectSequence {
  id        String @id @default("global")
  lastValue BigInt @default(0)
}

enum ProposalStatus {
  DRAFT
  INTERNAL_REVIEW
  SUBMITTED
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  SUPERSEDED
  ARCHIVED
}

model OperatingGroup {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  company                Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  engagementTypePolicies EngagementTypePolicyVersion[]
  proposals              Proposal[]

  @@unique([companyId, code])
  @@unique([id, companyId])
}

model EngagementTypePolicyVersion {
  id                        String   @id @default(cuid())
  companyId                 String
  operatingGroupId          String
  code                      String
  policyVersion             Int
  name                      String
  proposalRequired          Boolean
  directEngagementPermitted Boolean
  agreementTemplateCode     String
  agreementTemplateName     String
  billingMethod             String
  policy                    Json
  policyChecksum            String
  effectiveFrom             DateTime
  active                    Boolean  @default(true)
  createdAt                 DateTime @default(now())

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  operatingGroup OperatingGroup @relation(fields: [operatingGroupId, companyId], references: [id, companyId], onDelete: Restrict)
  proposals      Proposal[]

  @@unique([operatingGroupId, code, policyVersion])
  @@unique([id, companyId])
  @@index([companyId, active])
}

model ProposalSequence {
  id        String @id @default("global")
  lastValue BigInt @default(0)
}

model Proposal {
  id                     String         @id
  proposalNumber         String         @unique
  companyId              String
  operatingGroupId       String
  clientId               String
  ownerId                String
  engagementTypePolicyId String
  status                 ProposalStatus @default(DRAFT)
  currentVersionId       String?
  submittedVersionId     String?
  effectiveAt            DateTime?
  closedAt               DateTime?
  revisionOpen           Boolean        @default(false)
  currentAcceptanceId    String?
  executedAgreementId    String?
  supersededByProposalId String?
  draftRevision          Int            @default(1)
  versionDraftRevision   Int?
  nextVersionNumber      Int            @default(1)
  workingDraft           Json
  pricingSnapshot        Json
  aggregateState         Json
  createdAt              DateTime
  updatedAt              DateTime

  company              Company                     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  operatingGroup       OperatingGroup              @relation(fields: [operatingGroupId, companyId], references: [id, companyId], onDelete: Restrict)
  client               Client                      @relation(fields: [clientId, companyId], references: [id, companyId], onDelete: Restrict)
  owner                ApplicationUser             @relation(fields: [ownerId, companyId], references: [id, companyId], onDelete: Restrict)
  engagementTypePolicy EngagementTypePolicyVersion @relation(fields: [engagementTypePolicyId, companyId], references: [id, companyId], onDelete: Restrict)
  versions             ProposalVersion[]
  events               ProposalEvent[]
  outboxEvents         BusinessEventOutbox[]
  representations      ProposalRepresentation[]

  @@unique([id, companyId])
  @@index([companyId, clientId])
  @@index([companyId, status])
}

model ProposalVersion {
  id                   String   @id
  proposalId           String
  companyId            String
  versionNumber        Int
  createdAt            DateTime
  createdByUserId      String
  predecessorVersionId String?
  revisionReason       String?
  draft                Json

  proposal        Proposal                 @relation(fields: [proposalId, companyId], references: [id, companyId], onDelete: Restrict)
  pricingSource   ProposalPricingSource?
  representations ProposalRepresentation[]

  @@unique([proposalId, versionNumber])
  @@unique([id, proposalId])
  @@index([companyId])
}

model ProposalPricingSource {
  proposalVersionId    String @id
  proposalId           String
  pricingProjectId     String
  pricingProjectNumber String
  schemaVersion        Int
  snapshot             Json

  proposalVersion ProposalVersion @relation(fields: [proposalVersionId, proposalId], references: [id, proposalId], onDelete: Restrict)
  pricingProject  PricingProject  @relation(fields: [pricingProjectId], references: [id], onDelete: Restrict)

  @@unique([proposalVersionId, proposalId])
  @@index([pricingProjectId])
}

model ProposalEvent {
  eventId            String   @id
  proposalId         String
  companyId          String
  clientId           String
  occurredAt         DateTime
  eventType          String
  eventSchemaVersion Int
  payload            Json
  createdAt          DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId, companyId], references: [id, companyId], onDelete: Restrict)

  @@index([companyId, clientId, occurredAt, eventId])
}

model BusinessEventOutbox {
  eventId      String    @id
  proposalId   String
  companyId    String
  clientId     String
  occurredAt   DateTime
  eventType    String
  payload      Json
  publishedAt  DateTime?
  attemptCount Int       @default(0)
  lastError    String?   @db.Text
  createdAt    DateTime  @default(now())

  proposal Proposal @relation(fields: [proposalId, companyId], references: [id, companyId], onDelete: Restrict)

  @@index([publishedAt, occurredAt, eventId])
  @@index([companyId, clientId, occurredAt, eventId])
}

model ProposalRepresentation {
  id                 String   @id
  proposalId         String
  companyId          String
  proposalVersionId  String
  representationType String
  rendererVersion    String
  contentChecksum    String
  storageReference   String?
  generatedAt        DateTime

  proposal         Proposal                  @relation(fields: [proposalId, companyId], references: [id, companyId], onDelete: Restrict)
  proposalVersion  ProposalVersion           @relation(fields: [proposalVersionId, proposalId], references: [id, proposalId], onDelete: Restrict)
  deliveryAttempts ProposalDeliveryAttempt[]

  @@unique([id, companyId])
  @@index([proposalVersionId])
}

model ProposalDeliveryAttempt {
  id                String   @id
  companyId         String
  representationId  String
  channel           String
  recipientAddress  String
  providerReference String?
  status            String
  attemptedAt       DateTime
  errorCode         String?

  representation ProposalRepresentation @relation(fields: [representationId, companyId], references: [id, companyId], onDelete: Restrict)

  @@index([companyId, attemptedAt])
}

model ServiceCatalogItem {
  id             String                   @id @default(cuid())
  companyId      String
  code           String
  name           String
  description    String?                  @db.Text
  basePriceMinor BigInt
  currency       PricingCurrency          @default(USD)
  status         ServiceCatalogItemStatus @default(ACTIVE)
  sortOrder      Int
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  company Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lines   PricingProjectLine[]

  @@unique([companyId, code])
  @@unique([id, companyId])
  @@index([companyId, status, sortOrder])
}

model PricingConfiguration {
  id        String   @id @default(cuid())
  companyId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company                       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  versions PricingConfigurationVersion[]

  @@unique([id, companyId])
}

model PricingConfigurationVersion {
  id                     String                            @id @default(cuid())
  pricingConfigurationId String
  companyId              String
  version                Int
  status                 PricingConfigurationVersionStatus @default(ACTIVE)
  schemaVersion          Int
  engineVersion          String
  currency               PricingCurrency                   @default(USD)
  configuration          Json
  effectiveFrom          DateTime
  createdAt              DateTime                          @default(now())

  pricingConfiguration PricingConfiguration @relation(fields: [pricingConfigurationId, companyId], references: [id, companyId], onDelete: Restrict)
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)
  pricingProjects      PricingProject[]

  @@unique([pricingConfigurationId, version])
  @@unique([id, companyId])
  @@index([companyId, status])
}

model PricingProject {
  id                            String               @id @default(cuid())
  estimateNumber                String               @unique
  companyId                     String
  clientId                      String
  ownerId                       String
  sourcePricingProjectId        String?
  pricingConfigurationVersionId String
  projectName                   String               @db.VarChar(200)
  pricingModel                  PricingModelType     @default(PROJECT)
  methodologyVersion            String               @default("project-pricing/1.0.0")
  pricingInputSnapshot          Json                 @default("{}")
  pricingOutputSnapshot         Json                 @default("{}")
  status                        PricingProjectStatus @default(DRAFT)
  currency                      PricingCurrency      @default(USD)
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt

  company                Company                      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  client                 Client                       @relation(fields: [clientId, companyId], references: [id, companyId], onDelete: Restrict)
  owner                  ApplicationUser              @relation(fields: [ownerId, companyId], references: [id, companyId], onDelete: Restrict)
  configurationVersion   PricingConfigurationVersion  @relation(fields: [pricingConfigurationVersionId, companyId], references: [id, companyId], onDelete: Restrict)
  sourcePricingProject   PricingProject?              @relation("PricingProjectSource", fields: [sourcePricingProjectId, companyId], references: [id, companyId], onDelete: Restrict)
  derivedPricingProjects PricingProject[]             @relation("PricingProjectSource")
  lines                  PricingProjectLine[]
  complexitySelections   PricingComplexitySelection[]
  discountSelection      PricingDiscountSelection?
  proposalPricingSources ProposalPricingSource[]

  @@unique([id, companyId])
  @@index([companyId, status])
  @@index([companyId, clientId])
  @@index([companyId, updatedAt])
  @@index([ownerId])
  @@index([sourcePricingProjectId])
}

model PricingProjectLine {
  id                   String   @id @default(cuid())
  companyId            String
  pricingProjectId     String
  serviceCatalogItemId String
  quantity             Decimal  @db.Decimal(18, 2)
  sortOrder            Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  pricingProject     PricingProject     @relation(fields: [pricingProjectId, companyId], references: [id, companyId], onDelete: Cascade)
  serviceCatalogItem ServiceCatalogItem @relation(fields: [serviceCatalogItemId, companyId], references: [id, companyId], onDelete: Restrict)

  @@index([pricingProjectId, sortOrder])
  @@index([serviceCatalogItemId])
}

model PricingComplexitySelection {
  id               String @id @default(cuid())
  pricingProjectId String
  companyId        String
  factorCode       String
  optionCode       String
  sortOrder        Int

  pricingProject PricingProject @relation(fields: [pricingProjectId, companyId], references: [id, companyId], onDelete: Cascade)

  @@unique([pricingProjectId, factorCode])
  @@index([pricingProjectId, sortOrder])
}

model PricingDiscountSelection {
  id               String @id @default(cuid())
  pricingProjectId String
  companyId        String
  discountCode     String
  sortOrder        Int    @default(0)

  pricingProject PricingProject @relation(fields: [pricingProjectId, companyId], references: [id, companyId], onDelete: Cascade)

  @@unique([pricingProjectId, companyId])
}
